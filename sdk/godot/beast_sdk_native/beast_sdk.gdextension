[configuration]

entry_symbol = "beast_sdk_library_init"
compatibility_minimum = "4.2"

[libraries]

windows.debug.x86_64 = "res://beast_sdk_native/bin/windows/beast_sdk_native.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://beast_sdk_native/bin/windows/beast_sdk_native.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://beast_sdk_native/bin/linux/beast_sdk_native.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://beast_sdk_native/bin/linux/beast_sdk_native.linux.template_release.x86_64.so"
macos.debug = "res://beast_sdk_native/bin/macos/beast_sdk_native.macos.template_debug.universal.dylib"
macos.release = "res://beast_sdk_native/bin/macos/beast_sdk_native.macos.template_release.universal.dylib"
