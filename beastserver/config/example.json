{
  "server": {
    "node_id": "beast-node-001",
    "host": "127.0.0.1",
    "service_name": "beastserver",
    "net": {
      "tcp": {
        "port": 8010,
        "max_frame_bytes": 65536,
        "idle_timeout_seconds": 60,
        "io_thread_count": 4
      },
      "kcp": {
        "port": 0,
        "max_frame_bytes": 65536,
        "io_thread_count": 2,
        "conv": 0,
        "snd_wnd": 32,
        "rcv_wnd": 32,
        "nodelay": 1,
        "interval": 10,
        "resend": 2,
        "nc": 1
      }
    },
    "log": {
      "level": "error",
      "short_source": true,
      "logger_name": "beast"
    },
    "etcd": {
      "endpoints": "http://127.0.0.1:2379",
      "ttl_seconds": 10,
      "report_interval_seconds": 5,
      "register": {
        "domain": "game",
        "version": "v1",
        "weight": 10,
        "addr": "127.0.0.1:9010",
        "ttl": 10
      }
    },
    "grpc": {
      "port": 9010
    },
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "beastserver",
      "min_pool_size": 10,
      "max_pool_size": 100,
      "thread_count": 4,
      "queue_max_size": 1000
    },
    "runtime": {
      "event_actors": {
        "count": 4,
        "queue_capacity": 65536
      },
      "loop_actors": {
        "count": 2,
        "tick_hz": 30,
        "queue_capacity": 8192
      },
      "timer_wheel": {
        "tick_duration_ms": 50,
        "wheel_size": 512
      }
    },
    "debug": {
      "enabled": false
    }
  },
  "plugins": {
    "dir": "plugins",
    "auto_load": true
  },
  "bizconfig": {
    "enabled": false,
    "dir": "bizconfig/server",
    "manifest": "manifest.json",
    "fail_on_missing": false
  },
  "ai": {
    "enabled": false,
    "default_provider": "volcengine",
    "default_model": "doubao-seed-2-0-pro-260215",
    "default_music_model": "doubao-music",
    "default_embedding_model": "doubao-embedding-vision-251215",
    "providers": {
      "volcengine": {
        "api_key": "",
        "access_key": "",
        "secret_key": "",
        "api_key_env": "BEAST_AI_API_KEY",
        "access_key_env": "BEAST_AI_ACCESS_KEY",
        "secret_key_env": "BEAST_AI_SECRET_KEY",
        "chat_endpoint": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
        "embedding_endpoint": "https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal",
        "timeout_seconds": 600,
        "max_concurrent": 10,
        "max_retries": 2
      },
      "openai": {
        "api_key": "",
        "api_key_env": "OPENAI_API_KEY",
        "chat_endpoint": "https://api.openai.com/v1/chat/completions",
        "embedding_endpoint": "https://api.openai.com/v1/embeddings",
        "timeout_seconds": 300,
        "max_concurrent": 10,
        "max_retries": 2
      }
    },
    "fallbacks": [],
    "tos": {
      "bucket": "",
      "region": "cn-beijing",
      "path_prefix": "/game/bgm",
      "auth": true,
      "signed_url_ttl": 300,
      "cdn_domain": ""
    }
  }
}
